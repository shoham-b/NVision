# Core Execution Config
NVISION_DEFAULT_REPEATS=5
NVISION_DEFAULT_RUNNERS=4
NVISION_MIN_RUNNERS=4
NVISION_DEFAULT_RUN_ALL=False
NVISION_DEFAULT_LOC_MAX_STEPS=1500
NVISION_DEFAULT_LOC_TIMEOUT_S=1500

# UI & Browser Flags
NVISION_DEFAULT_OPEN_BROWSER=False

# Output & Logs Config
NVISION_DEFAULT_OUT=
NVISION_DEFAULT_LOGS_ROOT=
NVISION_DEFAULT_LOG_LEVEL=INFO

# GCP Integration
NVISION_GCP=False
NVISION_GCP_BUCKET=nvision-artifacts-shoha

# Demo & Beta Specific
NVISION_DEMO_REPEATS=3
NVISION_DEMO_LOC_MAX_STEPS=60
NVISION_DEMO_LOC_TIMEOUT_S=300
NVISION_DEMO_OUT=
NVISION_DEMO_LOGS_ROOT=
NVISION_BETA_OUT=

# GCP Service Account
GOOGLE_APPLICATION_CREDENTIALS=

# SMC Belief Parameters (nvision.belief.smc_marginal)
NVISION_SMC_NUM_PARTICLES=1000           # Number of particles in the filter
NVISION_SMC_JITTER_SCALE=0.1            # Jitter std as fraction of per-dim std (non-full-covariance path)
NVISION_SMC_ESS_THRESHOLD=0.5           # Effective sample size fraction that triggers resampling
NVISION_SMC_USE_FULL_COVARIANCE=False   # Use NIST-style multivariate nudging + contraction
NVISION_SMC_A_PARAM=0.98                # Contraction factor toward mean after nudging (paper default)
NVISION_SMC_SCALE=True                  # Enable contraction step when use_full_covariance=True
NVISION_SMC_USE_INFORMATION_WEIGHTS=True # Use Fisher-info weighting instead of pure likelihood
NVISION_SMC_ANNEALED_JITTER=False       # Add continuous jitter on every update (not just resample)
NVISION_SMC_ANNEALED_JITTER_INITIAL=0.02   # Starting jitter scale for annealed jitter
NVISION_SMC_ANNEALED_JITTER_MIN=0.001      # Floor for annealed jitter decay
NVISION_SMC_ANNEALED_JITTER_DECAY=0.995    # Per-update decay multiplier for annealed jitter
NVISION_SMC_ELITISM_RATIO=0.2           # Top fraction of particles kept intact during resampling
