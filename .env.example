# GCP configuration
#
# 1. Go to GCP Console > IAM & Admin > Service Accounts
# 2. Create or select a service account, add the "Storage Object Admin" role
# 3. Click the service account > Keys > Add Key > Create new key > JSON
# 4. Download the JSON key file to a safe location
# 5. Set the path below (use forward slashes or double backslashes on Windows)

# Full path to your service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=C:/Users/YOUR_USER/Downloads/nvision-service-key.json

# Default GCP bucket name (used when --gcp-bucket is omitted)
NVISION_GCP_BUCKET=your-bucket-name

# Minimum number of parallel runners; if a task fails with MemoryError
# the runner count is reduced until it reaches this floor, after which
# the task is allowed to fail permanently.
# NVISION_MIN_RUNNERS=2

# --- Core Locator Defaults ---------------------------------------------------
#
# Default max_steps for locators (presets.py)
#
# NVISION_DEFAULT_LOC_MAX_STEPS=1500

# --- SMC Belief Parameters ---------------------------------------------------
#
# These control the Sequential Monte Carlo particle filter in
# nvision.belief.smc_marginal.
#
# NVISION_SMC_NUM_PARTICLES=1000
# NVISION_SMC_JITTER_SCALE=0.1
# NVISION_SMC_ESS_THRESHOLD=0.5
# NVISION_SMC_USE_FULL_COVARIANCE=False
# NVISION_SMC_A_PARAM=0.98
# NVISION_SMC_SCALE=True
# NVISION_SMC_USE_INFORMATION_WEIGHTS=True
# NVISION_SMC_ANNEALED_JITTER=False
# NVISION_SMC_ANNEALED_JITTER_INITIAL=0.02
# NVISION_SMC_ANNEALED_JITTER_MIN=0.001
# NVISION_SMC_ANNEALED_JITTER_DECAY=0.995
# NVISION_SMC_ELITISM_RATIO=0.2

# --- Grid Resolution Parameters ----------------------------------------------
#
# Grid resolution for belief builders (two_peak generators)
#
# NVISION_GRID_FREQ=96
# NVISION_GRID_WIDTH=64
# NVISION_GRID_DEPTH=48
# NVISION_GRID_BACKGROUND=48

# Grid resolution for NV-center generators
#
# NVISION_NV_GRID_FREQ=500
# NVISION_NV_GRID_LINEWIDTH=80
# NVISION_NV_GRID_FWHM_TOTAL=80
# NVISION_NV_GRID_LORENTZ_FRAC=60
# NVISION_NV_GRID_SPLIT=80
# NVISION_NV_GRID_K_NP=60
# NVISION_NV_GRID_DEPTH=100
# NVISION_NV_GRID_BACKGROUND=60

# --- Sobol Sweep Parameters --------------------------------------------------
#
# Stage 1 noise baseline collection
#
# NVISION_SOBOL_MIN_POINTS=255
# NVISION_SOBOL_MAX_POINTS=511
# NVISION_SOBOL_CHECK_INTERVAL=32

# Focus window inference
#
# NVISION_SOBOL_MIN_DEPTH_SIGMA=2.5
# NVISION_SOBOL_DEPTH_FRACTION=0.5
# NVISION_SOBOL_PAD_FRACTION=0.005

# --- Sweep Steps Parameters --------------------------------------------------
#
# Coverage factor and bounds for sweep step calculation
#
# NVISION_SWEEP_COVERAGE_FACTOR=3.0
# NVISION_SWEEP_MIN_STEPS=50
# NVISION_SWEEP_MAX_STEPS=500

# --- Noise Preset Parameters -------------------------------------------------
#
# Default noise levels for noise tiers
#
# NVISION_NOISE_GAUSS=0.01
# NVISION_NOISE_POISSON=3000.0
# NVISION_NOISE_OVER_PROBE=0.001

# --- Window/Refocus Parameters -----------------------------------------------
#
# Padding fractions for window inference
#
# NVISION_WINDOW_PADDING_FRAC=0.05
# NVISION_WINDOW_MIN_PADDING_FRAC=0.01
