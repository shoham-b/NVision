# GCP configuration
#
# 1. Go to GCP Console > IAM & Admin > Service Accounts
# 2. Create or select a service account, add the "Storage Object Admin" role
# 3. Click the service account > Keys > Add Key > Create new key > JSON
# 4. Download the JSON key file to a safe location
# 5. Set the path below (use forward slashes or double backslashes on Windows)

# Full path to your service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=C:/Users/YOUR_USER/Downloads/nvision-service-key.json

# Default GCP bucket name (used when --gcp-bucket is omitted)
NVISION_GCP_BUCKET=your-bucket-name

# Minimum number of parallel runners; if a task fails with MemoryError
# the runner count is reduced until it reaches this floor, after which
# the task is allowed to fail permanently.
# NVISION_MIN_RUNNERS=2

# --- SMC Belief Parameters ---------------------------------------------------
#
# These control the Sequential Monte Carlo particle filter in
# nvision.belief.smc_marginal.
#
# NVISION_SMC_NUM_PARTICLES=1000
# NVISION_SMC_JITTER_SCALE=0.1
# NVISION_SMC_ESS_THRESHOLD=0.5
# NVISION_SMC_USE_FULL_COVARIANCE=False
# NVISION_SMC_A_PARAM=0.98
# NVISION_SMC_SCALE=True
# NVISION_SMC_USE_INFORMATION_WEIGHTS=True
# NVISION_SMC_ANNEALED_JITTER=False
# NVISION_SMC_ANNEALED_JITTER_INITIAL=0.02
# NVISION_SMC_ANNEALED_JITTER_MIN=0.001
# NVISION_SMC_ANNEALED_JITTER_DECAY=0.995
# NVISION_SMC_ELITISM_RATIO=0.2
