# GCP configuration
#
# 1. Go to GCP Console > IAM & Admin > Service Accounts
# 2. Create or select a service account, add the "Storage Object Admin" role
# 3. Click the service account > Keys > Add Key > Create new key > JSON
# 4. Download the JSON key file to a safe location
# 5. Set the path below (use forward slashes or double backslashes on Windows)

# Full path to your service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=C:/Users/YOUR_USER/Downloads/nvision-service-key.json

# Default GCP bucket name (used when --gcp-bucket is omitted)
NVISION_GCP_BUCKET=your-bucket-name
